---
import Container from "@components/Container.astro";
import Link from "@components/Link.astro";
import { SITE } from "@consts";
---

<header transition:persist>
  <Container>
    <div class="flex flex-wrap justify-between gap-y-2">
      <Link href="/" underline={false}>
        <div class="inline-flex items-center gap-1.5 font-semibold">
          <span>{SITE.TITLE}</span>
          <span class="text-[var(--color-accent)]" aria-hidden="true">~/</span>
        </div>
      </Link>
      <nav class="flex items-center gap-1.5 text-sm font-semibold">
        <Link href="/blog">blog</Link>
        <span class="text-black/25 dark:text-white/25">·</span>
        <Link href="/tags">tags</Link>
        <span class="text-black/25 dark:text-white/25">·</span>
        <button
          id="magnifying-glass"
          aria-label="Search"
          class="inline-block text-current underline decoration-black/30 underline-offset-[3px] transition-colors duration-300 ease-in-out hover:text-[var(--color-accent)] hover:decoration-[var(--color-accent)]/60 focus-visible:text-[var(--color-accent)] focus-visible:decoration-[var(--color-accent)]/60 focus-visible:outline-none dark:decoration-white/30"
        >
          search
        </button>
      </nav>
    </div>
  </Container>
</header>
