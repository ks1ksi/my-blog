---
import "../styles/global.css";
import { ClientRouter } from "astro:transitions";
import { SITE } from "@consts";

interface Props {
  title: string;
  description: string;
  image?: string;
  type?: "website" | "article";
  publishedTime?: string | Date;
  modifiedTime?: string | Date;
  tags?: string[];
  noindex?: boolean;
  jsonLd?: Record<string, unknown> | Record<string, unknown>[];
}

const {
  title,
  description,
  image = "/og.jpg",
  type = "website",
  publishedTime,
  modifiedTime,
  tags = [],
  noindex = false,
  jsonLd,
} = Astro.props;
const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const absoluteImageURL = new URL(image, Astro.site);
const imageAlt = title === SITE.TITLE ? SITE.TITLE : `${title} - ${SITE.TITLE}`;
const jsonLdItems = (Array.isArray(jsonLd) ? jsonLd : [jsonLd]).filter(Boolean);
const serializeJsonLd = (item: Record<string, unknown>) =>
  JSON.stringify(item).replace(/</g, "\\u003c");
const toIsoString = (date: string | Date) =>
  date instanceof Date ? date.toISOString() : date;
---

<!-- Global Metadata -->
<meta charset="utf-8" />
<meta name="viewport" content="width=device-width,initial-scale=1" />
<link rel="icon" type="image/webp" href="/icon.webp" />
<link rel="alternate" type="application/rss+xml" title={SITE.TITLE} href="/rss.xml" />
<meta name="generator" content={Astro.generator} />
<meta name="robots" content={noindex ? "noindex,follow" : "index,follow"} />
<meta name="author" content={SITE.TITLE} />
<meta
  name="naver-site-verification"
  content="bf086187e0346e29d6a4cc46934cf84a85d74c76"
/>

<!-- Canonical URL -->
<link rel="canonical" href={canonicalURL.href} />

<!-- Primary Meta Tags -->
<title>{title}</title>
<meta name="title" content={title} />
<meta name="description" content={description} />

<!-- Open Graph / Facebook -->
<meta property="og:type" content={type} />
<meta property="og:url" content={canonicalURL.href} />
<meta property="og:site_name" content={SITE.TITLE} />
<meta property="og:locale" content="ko_KR" />
<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
<meta property="og:image" content={absoluteImageURL.href} />
<meta property="og:image:alt" content={imageAlt} />

{
  type === "article" && publishedTime && (
    <meta property="article:published_time" content={toIsoString(publishedTime)} />
  )
}
{
  type === "article" && modifiedTime && (
    <meta property="article:modified_time" content={toIsoString(modifiedTime)} />
  )
}
{type === "article" && <meta property="article:author" content={SITE.TITLE} />}
{
  type === "article" &&
    tags.map((tag) => <meta property="article:tag" content={tag} />)
}

<!-- Twitter -->
<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:url" content={canonicalURL.href} />
<meta name="twitter:title" content={title} />
<meta name="twitter:description" content={description} />
<meta name="twitter:image" content={absoluteImageURL.href} />
<meta name="twitter:image:alt" content={imageAlt} />

{
  jsonLdItems.map((item) => (
    <script
      is:inline
      type="application/ld+json"
      set:html={serializeJsonLd(item as Record<string, unknown>)}
    />
  ))
}

<ClientRouter />

<script is:inline>
  const storedTheme = localStorage.getItem("theme");
  const prefersDarkTheme = window.matchMedia("(prefers-color-scheme: dark)").matches;
  const shouldUseDarkTheme =
    storedTheme === "dark" || (storedTheme !== "light" && prefersDarkTheme);

  document.documentElement.classList.toggle("dark", shouldUseDarkTheme);
</script>

<script>
  import { registerGlobalUi } from "@lib/client";

  registerGlobalUi();
</script>
