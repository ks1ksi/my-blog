---
import Layout from "@layouts/Layout.astro";
import Container from "@components/Container.astro";
import { getTagsWithPosts } from "@lib/content";

const tags = await getTagsWithPosts();
---

<Layout title="Tags" description="Browse posts by tag">
  <Container size="page">
    <div class="space-y-8">
      <div class="space-y-3">
        <h1 class="font-semibold text-black dark:text-white">All tags</h1>
        <p class="text-sm text-black/50 dark:text-white/50">
          {tags.length} tags
        </p>
      </div>

      <div class="flex flex-wrap gap-2">
        {
          tags.map(({ tag, count }) => (
            <a
              href={`/tags/${tag}`}
              class="inline-flex items-center gap-1.5 rounded-sm border border-black/15 px-2 py-1 text-sm transition-colors duration-300 ease-in-out hover:bg-[var(--color-accent-subtle)] hover:text-black focus-visible:bg-[var(--color-accent-subtle)] focus-visible:text-black dark:border-white/20 dark:hover:bg-[var(--color-accent-subtle)] dark:hover:text-white dark:focus-visible:bg-[var(--color-accent-subtle)] dark:focus-visible:text-white"
            >
              <span>{tag}</span>
              <span class="font-mono text-xs text-black/45 dark:text-white/45">
                {count}
              </span>
            </a>
          ))
        }
      </div>
    </div>
  </Container>
</Layout>
