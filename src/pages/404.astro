---
import Layout from "@layouts/Layout.astro";
import Container from "@components/Container.astro";
import BackToPrevious from "@components/BackToPrevious.astro";
import { SITE } from "@consts";
---

<Layout title="404" description={SITE.DESCRIPTION} noindex>
  <Container>
    <div class="mt-16 grid place-items-center gap-3">
      <h1 class="text-2xl font-semibold text-black dark:text-white">
        404: Page not found
      </h1>
      <span>
        <BackToPrevious href="/">Back home</BackToPrevious>
      </span>
    </div>
  </Container>
</Layout>
