---
import Layout from "@layouts/Layout.astro";
import Container from "@components/Container.astro";
import ArrowCard from "@components/ArrowCard.astro";
import { BLOG } from "@consts";
import { getPostsGroupedByYear } from "@lib/content";
import { createBreadcrumbJsonLd, getCanonicalUrl } from "@lib/seo";

const postsByYear = await getPostsGroupedByYear();
const jsonLd = [
  {
    "@context": "https://schema.org",
    "@type": "CollectionPage",
    name: BLOG.TITLE,
    description: BLOG.DESCRIPTION,
    url: getCanonicalUrl(Astro.url.pathname),
    inLanguage: "ko-KR",
  },
  createBreadcrumbJsonLd([
    { name: "Home", url: getCanonicalUrl("/") },
    { name: "Blog", url: getCanonicalUrl(Astro.url.pathname) },
  ]),
];
---

<Layout title={BLOG.TITLE} description={BLOG.DESCRIPTION} jsonLd={jsonLd}>
  <Container size="page">
    <aside data-pagefind-ignore>
      <div class="space-y-10">
        <h1 class="font-semibold text-black dark:text-white">Blog</h1>
        <div class="space-y-4">
          {
            postsByYear.map(({ year, posts }, yearIndex) => (
              <details
                id={`year-${year}`}
                class="group/year space-y-4"
                data-year-details
                data-year={year}
                open={yearIndex < 2}
              >
                <summary class="flex cursor-pointer list-none items-center justify-between border-b border-black/10 pb-2 text-black transition-colors marker:hidden hover:text-[var(--color-accent)] dark:border-white/10 dark:text-white [&::-webkit-details-marker]:hidden">
                  <span class="flex items-center gap-2 font-semibold">
                    <span class="inline-block transition-transform group-open/year:rotate-90">
                      ›
                    </span>
                    {year}
                  </span>
                  <span class="text-xs font-normal text-black/45 dark:text-white/45">
                    {posts.length} posts
                  </span>
                </summary>
                <div class="pt-4">
                  <ul class="not-prose grid gap-x-8 lg:grid-cols-2">
                    {posts.map((post) => (
                      <li>
                        <ArrowCard entry={post} />
                      </li>
                    ))}
                  </ul>
                </div>
              </details>
            ))
          }
        </div>
      </div>
    </aside>
  </Container>
</Layout>
