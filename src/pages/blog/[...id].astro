---
import { render } from "astro:content";
import Layout from "@layouts/Layout.astro";
import Container from "@components/Container.astro";
import FormattedDate from "@components/FormattedDate.astro";
import { readingTime } from "@lib/utils";
import BackToPrevious from "@components/BackToPrevious.astro";
import PostNavigation from "@components/PostNavigation.astro";
import TableOfContents from "@components/TableOfContents.astro";
import Giscus from "@components/Giscus.astro";
import { type BlogPost, getPublishedPosts } from "@lib/content";

export async function getStaticPaths() {
  const posts = await getPublishedPosts();
  return posts.map((post, index) => ({
    params: { id: post.id },
    props: {
      post,
      prevPost: posts[index - 1],
      nextPost: posts[index + 1],
    },
  }));
}

type Props = {
  post: BlogPost;
  prevPost?: BlogPost;
  nextPost?: BlogPost;
};

const { post, prevPost, nextPost } = Astro.props;
const { Content, headings } = await render(post);
---

<Layout
  title={post.data.title}
  description={post.data.description ?? post.data.title}
  type="article"
>
  <Container size="article">
    <div>
      <BackToPrevious href="/blog">Back to posts</BackToPrevious>
    </div>
    <div class="my-12 space-y-4 lg:my-16">
      <div
        class="flex flex-wrap items-center gap-x-2 gap-y-1 text-sm text-black/50 dark:text-white/50"
      >
        <div>
          <FormattedDate date={post.data.date} />
        </div>
        <span aria-hidden="true">&bull;</span>
        {post.body && <div>{readingTime(post.body)}</div>}
      </div>
      <h1
        class="max-w-3xl text-3xl leading-tight font-semibold text-black lg:text-4xl dark:text-white"
      >
        {post.data.title}
      </h1>
      {
        post.data.tags && post.data.tags.length > 0 ? (
          <div class="flex flex-wrap gap-2 pt-1">
            {post.data.tags.map((tag) => (
              <a
                href={`/tags/${tag}`}
                class="rounded-sm border border-[var(--color-border)] px-2 py-1 text-sm text-black/60 transition-colors duration-300 ease-in-out hover:bg-[var(--color-accent-subtle)] hover:text-black focus-visible:bg-[var(--color-accent-subtle)] focus-visible:text-black dark:text-white/60 dark:hover:text-white dark:focus-visible:text-white"
              >
                {tag}
              </a>
            ))}
          </div>
        ) : null
      }
    </div>
    {headings.length > 0 && <TableOfContents headings={headings} />}
    <article>
      <Content />
      <div class="mt-16">
        <PostNavigation prevPost={prevPost} nextPost={nextPost} />
      </div>
      <div class="mt-16">
        <Giscus />
      </div>
    </article>
  </Container>
</Layout>

<script is:inline data-astro-rerun>
  (() => {
    const previousPathStorageKey = "navigation:previous-path";
    const normalizePathname = (pathname = window.location.pathname) => {
      const normalizedPathname = pathname.replace(/\/$/, "");
      return normalizedPathname || "/";
    };

    const rememberCurrentPath = () => {
      sessionStorage.setItem(previousPathStorageKey, normalizePathname());
    };

    window.addEventListener("pagehide", rememberCurrentPath);
    document.addEventListener("click", (event) => {
      const target = event.target;
      if (!(target instanceof Element)) {
        return;
      }

      const link = target.closest("a");
      if (!link?.href) {
        return;
      }

      const url = new URL(link.href);
      if (url.origin === window.location.origin && url.pathname === "/blog") {
        rememberCurrentPath();
      }
    });
  })();
</script>
