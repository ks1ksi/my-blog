---
import Layout from "@layouts/Layout.astro";
import Container from "@components/Container.astro";
import { SITE, HOME, SOCIALS } from "@consts";
import ArrowCard from "@components/ArrowCard.astro";
import Link from "@components/Link.astro";
import { getRecentPosts } from "@lib/content";

const blog = await getRecentPosts(SITE.NUM_POSTS_ON_HOMEPAGE);
---

<Layout title={HOME.TITLE} description={HOME.DESCRIPTION}>
  <Container size="page">
    <aside data-pagefind-ignore>
      <h1 class="text-2xl font-semibold text-black lg:text-4xl dark:text-white">
        Welcome to my blog!
      </h1>
      <div class="space-y-14 lg:space-y-16">
        <section class="mt-4">
          <article class="max-w-2xl">
            <p class="text-lg text-black/65 dark:text-white/65">
              Software Engineer, Kotlin / Spring Boot
            </p>
          </article>
        </section>

        <section class="space-y-5">
          <div class="flex flex-wrap items-center justify-between gap-y-2">
            <h2 class="font-semibold text-black dark:text-white">
              Recent posts
            </h2>
            <Link href="/blog">All posts</Link>
          </div>
          <ul class="not-prose grid gap-x-8 lg:grid-cols-2">
            {
              blog.map((post) => (
                <li>
                  <ArrowCard entry={post} />
                </li>
              ))
            }
          </ul>
        </section>
        <section class="space-y-4">
          <h2 class="font-semibold text-black dark:text-white">Contact</h2>
          <ul class="not-prose flex flex-wrap gap-2">
            {
              SOCIALS.map((SOCIAL) => (
                <li class="flex gap-x-2 text-nowrap">
                  <Link
                    href={SOCIAL.HREF}
                    external
                    aria-label={`${SITE.TITLE} on ${SOCIAL.NAME}`}
                  >
                    {SOCIAL.NAME}
                  </Link>
                  {"/"}
                </li>
              ))
            }
            <li class="line-clamp-1">
              <Link
                href={`mailto:${SITE.EMAIL}`}
                aria-label={`Email ${SITE.TITLE}`}
              >
                {SITE.EMAIL}
              </Link>
            </li>
          </ul>
        </section>
      </div>
    </aside>
  </Container>
</Layout>
